# OTA Platform — Environment variables template cho Vietnix VPS
# Copy file này sang /var/www/ota/backend/.env và điền giá trị thật.
# QUAN TRỌNG: chmod 600, owner ota:ota
# Tên biến KHỚP CHÍNH XÁC với backend/config.py để Pydantic load đúng.

# ─── Database (Postgres self-host) ────────────────────────────────────────────
# Password đặt lúc chạy postgres-tune.sh
DATABASE_URL=postgresql://ota:CHANGE_ME@127.0.0.1:5432/ota

# ─── App secret ───────────────────────────────────────────────────────────────
# Copy từ Render env SECRET_KEY (hoặc generate mới: openssl rand -base64 32)
SECRET_KEY=CHANGE_ME_RANDOM_32_CHARS

# ─── Google Sheets credentials ────────────────────────────────────────────────
# Full JSON service account — copy nguyên chuỗi 1 dòng từ Render env GOOGLE_CREDENTIALS_JSON
# Format: {"type":"service_account","project_id":"...","private_key":"-----BEGIN ...\\n...\\n-----END...\\n",...}
# QUAN TRỌNG: phải bao trong DẤU NHÁY ĐƠN ' ' để bash không expand $, \n
GOOGLE_CREDENTIALS_JSON='CHANGE_ME_PASTE_FULL_JSON_HERE'

# ─── Google Sheets target ─────────────────────────────────────────────────────
SHEET_ID=1sI34D88zsmSrN7Jf9fS3jh4aUvaep-blxnBR1CGq9eM

# GID các tab Sheet (default đã match Sheet hiện tại, có thể giữ nguyên)
GID_MAIN=1729132868
GID_VIETRAVEL=620817544
GID_FINDTOURGO=408521834
GID_ROUTE_RULES=58839224

# ─── Scraper schedule (giờ VN, cron 24h format) ──────────────────────────────
SCRAPER_SCHEDULE_HOUR=7
SCRAPER_SCHEDULE_MINUTE=0

# ─── Cron secret (cho POST /api/cron/tick từ GitHub Actions hoặc cron ngoài) ─
# Để trống nếu không dùng cron ngoài
CRON_SECRET=

# ─── Company config ───────────────────────────────────────────────────────────
COMPANY_NAME=Vietravel

# ─── Redis cache (persist compare cache qua restart) ─────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── App env flag (KHÔNG cần set RENDER vì đây không phải Render) ───────────
# Backend auto-detect và bỏ qua các logic Supabase-specific
