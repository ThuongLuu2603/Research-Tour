# Supabase — trên Render BẮT BUỘC dùng Session pooler (IPv4), không dùng db.*.supabase.co trực tiếp
# Dashboard → Project Settings → Database → Connection string → Session pooler → URI
# Mật khẩu có @ → encode %40. User dạng postgres.PROJECT_REF (không chỉ postgres)
#
# Cách 1 (khuyên dùng Render): chỉ set DATABASE_POOLER_URL
# Chỉ MỘT @ trước host (không @@). Ví dụ Tokyo pooler:
# DATABASE_POOLER_URL=postgresql://postgres.hjoqbknulolkxqqwjxno:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
#
# Cách 2: DATABASE_URL direct — app tự đổi sang pooler khi chạy trên Render (SUPABASE_REGION=ap-southeast-1)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# SUPABASE_POOLER_HOST=aws-0-ap-southeast-1.pooler.supabase.com

SECRET_KEY=generate-with-openssl-rand-hex-32
SHEET_ID=1sI34D88zsmSrN7Jf9fS3jh4aUvaep-blxnBR1CGq9eM
GOOGLE_CREDENTIALS_FILE=credentials.json
# Render: paste full JSON content (one line) — do NOT commit this file
GOOGLE_CREDENTIALS_JSON=
